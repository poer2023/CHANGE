# GLM-4.5 API 配置
# 请复制此文件为 .env.local 并填入真实的API密钥

# GLM API密钥 - 从智谱AI开放平台获取 (https://open.bigmodel.cn/)
VITE_GLM_API_KEY=your_glm_api_key_here

# GLM API基础URL (可选，默认为官方地址)
VITE_GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# GLM默认模型 (可选)
VITE_GLM_DEFAULT_MODEL=glm-4-flash

# API超时时间 (毫秒，可选)
VITE_GLM_TIMEOUT=30000

# API重试次数 (可选)
VITE_GLM_MAX_RETRIES=3

# GLM API重试延迟 (毫秒，可选)
VITE_GLM_RETRY_DELAY=1000

# GLM API速率限制 (请求/分钟，可选)
VITE_GLM_RATE_LIMIT=60

# 连接测试超时时间 (毫秒，可选)
VITE_GLM_CONNECTION_TIMEOUT=10000

# 是否启用API缓存 (可选)
VITE_GLM_ENABLE_CACHE=true

# 缓存过期时间 (分钟，可选)
VITE_GLM_CACHE_DURATION=30

# 错误处理配置
VITE_GLM_ENABLE_ERROR_REPORTING=true
VITE_GLM_MAX_ERROR_LOGS=100

# 性能监控配置
VITE_GLM_ENABLE_PERFORMANCE_MONITORING=true
VITE_GLM_PERFORMANCE_SAMPLE_RATE=0.1

# 开发模式配置
VITE_DEV_MODE=true

# 是否启用调试日志
VITE_DEBUG_MODE=false

# 是否使用模拟数据（当API密钥未配置时的后备方案）
VITE_USE_MOCK_DATA=true

# =====================================
# 配置说明:
# =====================================
# 1. 复制此文件为 .env.local
# 2. 在智谱AI开放平台注册账号: https://open.bigmodel.cn/
# 3. 获取API密钥并替换 your_glm_api_key_here
# 4. 根据需要调整其他配置参数
# 5. 保存文件并重启开发服务器
# 
# 重要提示:
# - .env.local 文件不会被git跟踪，确保API密钥安全
# - 环境变量名必须以 VITE_ 开头才能在前端代码中使用
# - 修改环境变量后需要重启开发服务器才能生效
# 
# GLM-4模型说明:
# - glm-4-flash: 免费版本，适合开发测试
# - glm-4: 标准版本，平衡性能和成本
# - glm-4-plus: 高级版本，最佳性能
# 
# 配置优化建议:
# - 生产环境建议设置更高的超时时间和重试次数
# - 开发环境可启用调试模式和性能监控
# - 根据API配额调整速率限制设置
# - 启用缓存可以提高响应速度并减少API调用
# 
# 错误处理配置:
# - ENABLE_ERROR_REPORTING: 是否收集和报告错误信息
# - MAX_ERROR_LOGS: 最大错误日志数量，避免内存泄漏
# 
# 性能监控配置:
# - ENABLE_PERFORMANCE_MONITORING: 是否启用性能监控
# - PERFORMANCE_SAMPLE_RATE: 性能数据采样率 (0.0-1.0)
# 
# API限制说明:
# - 免费版本有请求频率和token限制
# - 付费版本有更高的配额和性能
# - 详细限制请查看智谱AI官方文档
EOF < /dev/null
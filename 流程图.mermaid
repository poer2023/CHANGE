---
title: AI论文写作助手系统流程图
---

# 1. 整体系统架构流程图
graph TB
    subgraph "用户界面层"
        A[首页 HomePage] --> B[创建页面 CreatePage]
        B --> C[渐进式表单 FormPage]
        C --> D[模块化编辑器 ModularEditor]
        D --> E[论文管理 Dashboard]
        
        F[登录注册 Auth] --> G[用户认证]
        G --> H[受保护路由 ProtectedRoute]
    end
    
    subgraph "业务逻辑层"
        I[PaperStore 论文状态管理]
        J[AgentStore AI助手状态]
        K[UIStore 界面状态]
        L[UserStore 用户状态]
    end
    
    subgraph "AI服务层"
        M[学术写作专家 AcademicWritingExpert]
        N[研究助手 ResearchAssistant]
        O[格式专家 FormatExpert]
        P[内容顾问 ContentAdvisor]
    end
    
    subgraph "工具组件层"
        Q[UI组件库 Components/UI]
        R[编辑器组件 Editor Components]
        S[Agent组件 Agent Components]
        T[布局组件 Layout Components]
    end
    
    A --> I
    C --> I
    D --> I
    D --> J
    M --> J
    N --> J
    O --> J
    P --> J
    
    I --> Q
    J --> S
    K --> Q
    L --> T

---

# 2. 用户核心流程图
graph TD
    START([用户访问首页]) --> CHECK_AUTH{是否已登录?}
    
    CHECK_AUTH -->|否| LOGIN[登录/注册页面]
    CHECK_AUTH -->|是| HOMEPAGE[首页展示]
    
    LOGIN --> AUTH_SUCCESS{认证成功?}
    AUTH_SUCCESS -->|是| HOMEPAGE
    AUTH_SUCCESS -->|否| LOGIN
    
    HOMEPAGE --> CREATE_CHOICE{选择创建方式}
    
    CREATE_CHOICE -->|新建论文| STEP1[步骤1: 基本信息]
    CREATE_CHOICE -->|上传文档| UPLOAD[文档上传解析]
    CREATE_CHOICE -->|使用模板| TEMPLATE[选择模板]
    
    UPLOAD --> STEP1
    TEMPLATE --> STEP1
    
    subgraph "渐进式表单流程"
        STEP1 --> STEP1_CONTENT[标题/类型/领域/语言]
        STEP1_CONTENT --> STEP2[步骤2: 内容结构]
        STEP2 --> STEP2_CONTENT[大纲偏好/详细程度/字数要求]
        STEP2_CONTENT --> STEP3[步骤3: 参考文献]
        STEP3 --> STEP3_CONTENT[引用风格/文献管理]
        STEP3_CONTENT --> STEP4[步骤4: 生成论文]
        STEP4 --> STEP4_CONTENT[AI生成初稿]
    end
    
    STEP4_CONTENT --> EDITOR[模块化编辑器]
    
    subgraph "编辑阶段"
        EDITOR --> EDIT_MODULE[编辑论文模块]
        EDIT_MODULE --> AI_ASSIST[AI助手优化]
        AI_ASSIST --> PREVIEW[预览效果]
        PREVIEW --> CONTINUE_EDIT{继续编辑?}
        CONTINUE_EDIT -->|是| EDIT_MODULE
        CONTINUE_EDIT -->|否| EXPORT[导出发布]
    end
    
    EXPORT --> SAVE[保存到管理面板]
    SAVE --> END([完成])
    
    EDITOR --> DASHBOARD[论文管理面板]
    DASHBOARD --> VIEW_PAPERS[查看所有论文]
    VIEW_PAPERS --> EDIT_EXISTING[编辑已有论文]
    EDIT_EXISTING --> EDITOR

---

# 3. AI Agent系统流程图
graph LR
    subgraph "Agent 输入层"
        A[用户输入/选择文本] --> B[上下文分析]
        B --> C[意图识别]
    end
    
    subgraph "Agent 路由层"
        C --> D{选择AI角色}
        D -->|学术写作| E[AcademicWritingExpert]
        D -->|研究支持| F[ResearchAssistant]  
        D -->|格式调整| G[FormatExpert]
        D -->|内容建议| H[ContentAdvisor]
    end
    
    subgraph "Agent 处理层"
        E --> I[学术写作建议生成]
        F --> J[研究方法建议生成]
        G --> K[格式规范建议生成]
        H --> L[内容优化建议生成]
    end
    
    subgraph "Agent 输出层"
        I --> M[建议展示]
        J --> M
        K --> M
        L --> M
        M --> N[用户确认]
        N --> O{接受建议?}
        O -->|是| P[应用修改]
        O -->|否| Q[继续编辑]
        P --> R[更新文档]
        Q --> A
    end
    
    subgraph "快捷操作"
        S[快捷操作栏] --> T[预定义操作]
        T --> U[直接应用]
        U --> R
    end


# 8.1 渐进式表单模块
graph TD
    START([开始表单填写]) --> STEP1[第一步: 基本信息]
    
    subgraph "步骤1: 基本信息收集"
        STEP1 --> TITLE[输入论文标题]
        TITLE --> TYPE[选择论文类型]
        TYPE --> FIELD[选择研究领域]
        FIELD --> LANG[选择写作语言]
        LANG --> STYLE[选择写作风格]
        STYLE --> VALIDATE1{验证输入}
        VALIDATE1 -->|失败| TITLE
        VALIDATE1 -->|成功| NEXT1[进入下一步]
    end
    
    NEXT1 --> STEP2[第二步: 内容结构]
    
    subgraph "步骤2: 结构设置"
        STEP2 --> OUTLINE[大纲偏好设置]
        OUTLINE --> DETAIL[详细程度选择]
        DETAIL --> WORDS[字数要求设置]
        WORDS --> REQUIREMENTS[特殊要求输入]
        REQUIREMENTS --> VALIDATE2{验证设置}
        VALIDATE2 -->|失败| OUTLINE
        VALIDATE2 -->|成功| NEXT2[进入下一步]
    end
    
    NEXT2 --> STEP3[第三步: 参考文献]
    
    subgraph "步骤3: 文献管理"
        STEP3 --> CITATION[引用风格选择]
        CITATION --> REFS[参考文献添加]
        REFS --> VALIDATE3{验证文献}
        VALIDATE3 -->|失败| REFS
        VALIDATE3 -->|成功| NEXT3[进入下一步]
    end
    
    NEXT3 --> STEP4[第四步: 生成论文]
    
    subgraph "步骤4: AI生成"
        STEP4 --> GENERATE[AI生成初稿]
        GENERATE --> PREVIEW[预览生成结果]
        PREVIEW --> SATISFIED{满意结果?}
        SATISFIED -->|否| REGENERATE[重新生成]
        REGENERATE --> GENERATE
        SATISFIED -->|是| SAVE[保存论文]
    end
    
    SAVE --> REDIRECT[跳转到编辑器]
    REDIRECT --> END([完成])

---

# 8.2 模块化编辑器流程
graph TD
    START([进入编辑器]) --> LOAD[加载论文数据]
    LOAD --> RENDER[渲染模块结构]
    
    subgraph "编辑器主界面"
        RENDER --> MODULES[显示论文模块]
        MODULES --> SELECT[选择模块]
        
        SELECT --> EDIT_OPTIONS{编辑选项}
        EDIT_OPTIONS --> EDIT_CONTENT[编辑内容]
        EDIT_OPTIONS --> MOVE_MODULE[移动模块]
        EDIT_OPTIONS --> DELETE_MODULE[删除模块]
        EDIT_OPTIONS --> ADD_MODULE[添加模块]
        
        EDIT_CONTENT --> RICH_EDITOR[富文本编辑器]
        RICH_EDITOR --> AUTO_SAVE[自动保存]
        
        MOVE_MODULE --> DRAG_DROP[拖拽排序]
        DRAG_DROP --> UPDATE_ORDER[更新顺序]
        
        ADD_MODULE --> MODULE_TEMPLATE[选择模块模板]
        MODULE_TEMPLATE --> INSERT[插入新模块]
        
        DELETE_MODULE --> CONFIRM[确认删除]
        CONFIRM --> REMOVE[移除模块]
    end
    
    AUTO_SAVE --> AI_PANEL[AI助手面板]
    UPDATE_ORDER --> AI_PANEL
    INSERT --> AI_PANEL
    REMOVE --> AI_PANEL
    
    subgraph "AI助手交互"
        AI_PANEL --> CHAT[与AI对话]
        AI_PANEL --> SUGGESTIONS[获取建议]
        AI_PANEL --> QUICK_ACTIONS[快捷操作]
        
        CHAT --> AI_RESPONSE[AI回复]
        SUGGESTIONS --> APPLY_SUGGESTION[应用建议]
        QUICK_ACTIONS --> DIRECT_EDIT[直接编辑]
        
        AI_RESPONSE --> ACCEPT{接受建议?}
        ACCEPT -->|是| APPLY_CHANGES[应用修改]
        ACCEPT -->|否| CONTINUE_CHAT[继续对话]
        
        APPLY_SUGGESTION --> UPDATE_CONTENT[更新内容]
        DIRECT_EDIT --> UPDATE_CONTENT
        APPLY_CHANGES --> UPDATE_CONTENT
    end
    
    UPDATE_CONTENT --> PREVIEW[预览效果]
    CONTINUE_CHAT --> CHAT
    
    PREVIEW --> EXPORT_OPTIONS{导出选项}
    EXPORT_OPTIONS --> EXPORT_PDF[导出PDF]
    EXPORT_OPTIONS --> EXPORT_WORD[导出Word]
    EXPORT_OPTIONS --> EXPORT_MD[导出Markdown]
    
    EXPORT_PDF --> DOWNLOAD[下载文件]
    EXPORT_WORD --> DOWNLOAD
    EXPORT_MD --> DOWNLOAD
    
    DOWNLOAD --> END([完成])
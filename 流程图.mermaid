# 5. 路由系统流程图
graph TD
    START([应用启动]) --> ROUTER[React Router]
    
    ROUTER --> PUBLIC{公共路由}
    ROUTER --> PROTECTED{受保护路由}
    
    subgraph "公共路由 Public Routes"
        PUBLIC --> HOME[/ - HomePage<br/>首页展示]
        PUBLIC --> CREATE[/create - CreatePage<br/>创建入口]
        PUBLIC --> FORM[/form - FormPage<br/>渐进式表单]
        PUBLIC --> DEMO1[/demo - ModularEditorDemo<br/>编辑器演示]
        PUBLIC --> DEMO2[/agent-demo - AgentDemo<br/>AI助手演示]
    end
    
    subgraph "认证路由 Auth Routes"
        PUBLIC --> LOGIN[/auth/login - LoginPage<br/>用户登录]
        PUBLIC --> REGISTER[/auth/register - RegisterPage<br/>用户注册]
    end
    
    subgraph "编辑器路由 Editor Routes"
        PROTECTED --> EDITOR1[/editor/:id - EditorPage<br/>传统编辑器]
        PROTECTED --> EDITOR2[/modular-editor/:id<br/>ModularEditorPage<br/>模块化编辑器]
    end
    
    subgraph "仪表板路由 Dashboard Routes (嵌套)"
        PROTECTED --> LAYOUT[/dashboard - Layout<br/>布局容器]
        LAYOUT --> DASH[/ - Dashboard<br/>仪表板首页]
        LAYOUT --> PAPERS[/papers - Papers<br/>论文管理]
        LAYOUT --> PROJECTS[/projects - Projects<br/>项目管理]
        LAYOUT --> TEMPLATES[/templates - Templates<br/>模板管理]
        LAYOUT --> CHAT[/chat - AI Assistant<br/>AI助手]
        LAYOUT --> REFS[/references - References<br/>参考文献]
        LAYOUT --> ANALYTICS[/analytics - Analytics<br/>数据分析]
    end
    
    PROTECTED --> GUARD[ProtectedRoute<br/>路由守卫]
    GUARD --> AUTH_CHECK{用户认证检查}
    AUTH_CHECK -->|已认证| ACCESS_GRANTED[允许访问]
    AUTH_CHECK -->|未认证| REDIRECT_LOGIN[重定向到登录]
    
    ROUTER --> NOTFOUND[/* - 404页面<br/>未匹配路由处理]

---

# 6. 组件架构层次图
graph TB
    subgraph "应用根层 App Root"
        APP[App.tsx<br/>应用根组件]
        APP --> ROUTER[BrowserRouter<br/>路由管理]
        APP --> ERROR[ErrorBoundary<br/>错误边界]
        APP --> TOAST[NotificationToast<br/>全局通知]
    end
    
    subgraph "页面层 Page Layer"
        ROUTER --> HOME[HomePage<br/>首页]
        ROUTER --> CREATE_PAGE[CreatePage<br/>创建页]
        ROUTER --> FORM_PAGE[FormPage<br/>表单页]
        ROUTER --> EDITOR_PAGE[ModularEditorPage<br/>编辑器页]
        ROUTER --> DASH_PAGE[Dashboard<br/>仪表板]
    end
    
    subgraph "布局层 Layout Layer"
        DASH_PAGE --> LAYOUT[Layout<br/>布局容器]
        LAYOUT --> HEADER[Header<br/>头部导航]
        LAYOUT --> SIDEBAR[Sidebar<br/>侧边栏]
        LAYOUT --> MAIN[主内容区]
    end
    
    subgraph "业务组件层 Business Component Layer"
        FORM_PAGE --> FORM_COMPONENTS[表单组件群]
        FORM_COMPONENTS --> PAPER_TYPE[PaperTypeSelector<br/>论文类型选择]
        FORM_COMPONENTS --> FIELD_SELECT[FieldSelector<br/>领域选择]
        FORM_COMPONENTS --> OUTLINE_PREF[OutlinePreference<br/>大纲偏好]
        FORM_COMPONENTS --> AI_PARSER[AIRequirementParser<br/>AI需求解析]
        
        EDITOR_PAGE --> EDITOR_COMPONENTS[编辑器组件群]
        EDITOR_COMPONENTS --> MODULAR_EDITOR[ModularEditor<br/>模块化编辑器]
        EDITOR_COMPONENTS --> STRUCTURE_TREE[StructureTree<br/>结构树]
        EDITOR_COMPONENTS --> MODULE_CARD[ModuleCard<br/>模块卡片]
        EDITOR_COMPONENTS --> PROGRESS_TRACKER[ProgressTracker<br/>进度追踪]
        EDITOR_COMPONENTS --> TEMPLATE_LIB[TemplateLibrary<br/>模板库]
        
        EDITOR_PAGE --> AGENT_COMPONENTS[AI助手组件群]
        AGENT_COMPONENTS --> AGENT_PANEL[AgentPanel<br/>AI助手面板]
        AGENT_COMPONENTS --> CHAT_INTERFACE[ChatInterface<br/>聊天界面]
        AGENT_COMPONENTS --> SUGGESTION_CARD[AgentSuggestionCard<br/>建议卡片]
        AGENT_COMPONENTS --> ROLE_SWITCHER[AgentRoleSwitcher<br/>角色切换]
        AGENT_COMPONENTS --> QUICK_ACTION[QuickActionBar<br/>快捷操作栏]
    end
    
    subgraph "UI基础组件层 UI Component Layer"
        UI_COMPONENTS[UI组件库]
        UI_COMPONENTS --> BUTTON[Button<br/>按钮]
        UI_COMPONENTS --> INPUT[Input<br/>输入框]
        UI_COMPONENTS --> CARD[Card<br/>卡片]
        UI_COMPONENTS --> MODAL[Modal<br/>弹窗]
        UI_COMPONENTS --> LOADING[LoadingSpinner<br/>加载动画]
        UI_COMPONENTS --> TOAST_COMP[Toast<br/>提示信息]
        UI_COMPONENTS --> FORM_FIELD[FormField<br/>表单字段]
        UI_COMPONENTS --> PROGRESS[Progress<br/>进度条]
    end
    
    subgraph "工具层 Utility Layer"
        UTILS[工具函数]
        UTILS --> VALIDATION[validation<br/>表单验证]
        UTILS --> FORMATTERS[formatters<br/>格式化工具]
        UTILS --> ANIMATIONS[animations<br/>动画工具]
        UTILS --> EXPORT_UTILS[exportUtils<br/>导出工具]
        UTILS --> CN[cn<br/>样式合并工具]
    end

